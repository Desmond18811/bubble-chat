# Bubble Chat - Frontend environment variables
# Copy this to .env (or .env.local) and provide values

# Backend URL (use localhost for browser access even if Docker is bridged)
VITE_API_URL=http://localhost:3000/api/v1

# Zego Cloud credentials (REQUIRED for Meet section)
VITE_ZEGO_APP_ID=your_zego_app_id
VITE_ZEGO_SERVER_SECRET=your_zego_server_secret
