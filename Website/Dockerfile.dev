FROM node:22-alpine

# Set working directory
WORKDIR /usr/src/app

# Install pnpm globally
RUN npm install -g pnpm

# Copy package files
COPY package.json pnpm-lock.yaml* ./

# Install dependencies
RUN pnpm install

# Copy application source
COPY . .

# Expose frontend port
EXPOSE 8080

# Start Vite dev server
CMD ["pnpm", "dev"]
