{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://bubble-backend-production-96a0.up.railway.app/api/v1",
        "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY": "pk_test_your_clerk_publishable_key"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://bubble-backend-production-96a0.up.railway.app/api/v1",
        "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY": "pk_test_your_clerk_publishable_key"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://bubble-backend-production-96a0.up.railway.app/api/v1",
        "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY": "pk_live_your_clerk_publishable_key"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
