# Bubble Chat — Expo app environment template
# Copy to .env for local dev:  cp .env.example .env
# NOTE: EXPO_PUBLIC_* vars are inlined into the JS bundle at BUILD time.
# For EAS/APK builds the values come from eas.json build profiles (or EAS
# environment variables) — a local .env is NOT uploaded to EAS. Keep both in sync.

# Backend API base URL
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# Google OAuth — Web Client ID (must match backend GOOGLE_CLIENT_ID)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_web_client_id

# Clerk publishable key — Clerk Dashboard → API Keys.
# Powers ClerkProvider + Google OAuth sign-in in the app.
# Use pk_live_... for a production APK; pk_test_... for dev/preview builds.
# Must be paired with the matching CLERK_SECRET_KEY on the backend.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
