# Bubble Chat — Root .gitignore

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/

# Environment files — NEVER commit secrets
.env
.env.local
.env.*.local
*.env

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS artifacts
.DS_Store
Thumbs.db

# Editor artifacts
.vscode/
.idea/
*.iml
*.swp
*.swo
*~

# Test coverage
coverage/
.nyc_output/

# Media files — never commit raw media assets
*.mp4
*.mov
*.webm
*.avi
*.mkv
*.mp3
*.wav
*.ogg
*.aac
*.flac
*.amv
*.3gp
*.wmv
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff
*.heic
*.heif

# Upload temp directories
uploads/
tmp/
temp/

# Security-sensitive files
*.pem
*.key
*.p12
*.pfx
*.cert
*.crt
secrets/

# TypeScript
*.tsbuildinfo
