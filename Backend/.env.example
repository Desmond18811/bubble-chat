# === Core ===
PORT=3000
NODE_ENV=production
JWT_KEY=your_jwt_secret_key
JWT_REFRESH_KEY=your_jwt_refresh_secret_key
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# === Database & Cache ===
# For Docker, use: mongodb://mongodb:27017/bubble-chat
MONGODB_URI=mongodb://localhost:27017/bubble-chat
# For Docker, use: redis://redis:6379
REDIS_URL=redis://localhost:6379

# === External Links ===
SERVER_URL=http://localhost:3000
ORIGIN=http://localhost:5173

# === Google OAuth ===
# Note: GOOGLE_CLIENT_ID serves as the Web Client ID used for verification by the native mobile Sign-In route as well.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# === Storage (Filebase S3 or similar) ===
FILEBASE_ACCESS_KEY=your_access_key
FILEBASE_SECRET_KEY=your_secret_key
FILEBASE_BUCKET=your_bucket_name

# === Video/Audio Calls (ZegoCloud) ===
ZEGO_APP_ID=your_zego_app_id
ZEGO_SERVER_SECRET=your_zego_server_secret

# === Email (Nodemailer) ===
EMAIL_PROVIDER=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=Bubble Chat

# === Payments ===
PAYSTACK_SECRET_KEY=your_paystack_secret
STRIPE_SECRET_KEY=your_stripe_secret
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# === AI (Hugging Face) ===
HF_API_KEY=your_hugging_face_key
HF_MODEL_ID=meta-llama/Meta-Llama-3-8B-Instruct

# === Pinecone ===
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=bubble-org-knowledge

# === AWS S3 Storage (Additional Provider) ===
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_aws_s3_bucket_name

# === Video/Audio Calls (LiveKit Cloud) ===
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
# Set to 'true' to record call audio (room-composite egress) so meetings are
# transcribed via Whisper even on clients without live captions (mobile/Safari/Firefox).
# Requires the egress worker (LiveKit Cloud provides it; self-host needs the container).
LIVEKIT_EGRESS_ENABLED=true

# === Speech-to-Text (Whisper) ===
# Preferred: Groq runs whisper-large-v3 on an OpenAI-compatible API with a free tier.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
# Optional override; defaults to whisper-large-v3 (try whisper-large-v3-turbo for speed)
# GROQ_WHISPER_MODEL=whisper-large-v3
# Fallback only — used for transcription when GROQ_API_KEY is unset (needs OpenAI billing).
OPENAI_API_KEY=your_openai_api_key

# === DeepSeek (Aida & Transcript Summarizer AI) ===
DEEPSEEK_API_KEY=your_deepseek_api_key
